<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">
  <Id>slidessibility-accessibility-checker</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Slidessibility Team</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Slidessibility"/>
  <Description DefaultValue="Accessibility checker for PowerPoint presentations"/>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="PowerPointApi"/>
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:8080/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>
          <FunctionFile resid="CommandsUrl"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="SlidessibilityGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="CheckAccessibility">
                  <Label resid="TaskpaneButtonLabel"/>
                  <Supertip>
                    <Title resid="TaskpaneButtonLabel"/>
                    <Description resid="TaskpaneButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16x16"/>
                    <bt:Image size="32" resid="Icon32x32"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>SlidessibilityTaskpane</TaskpaneId>
                    <SourceLocation resid="TaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16x16" DefaultValue="https://via.placeholder.com/16/0078d4/ffffff?text=✓"/>
        <bt:Image id="Icon32x32" DefaultValue="https://via.placeholder.com/32/0078d4/ffffff?text=✓"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskpaneUrl" DefaultValue="https://localhost:8080/taskpane.html"/>
        <bt:Url id="CommandsUrl" DefaultValue="https://localhost:8080/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Slidessibility"/>
        <bt:String id="TaskpaneButtonLabel" DefaultValue="Check Accessibility"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButtonDesc" DefaultValue="Run WCAG accessibility checks"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>